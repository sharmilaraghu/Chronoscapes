# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
TURBOPUFFER_API_KEY=
OPENROUTER_API_KEY=

# ── turbopuffer ───────────────────────────────────────────────────────────────
TURBOPUFFER_NAMESPACE=chronoscopes-v2
TURBOPUFFER_REGION=aws-us-east-1

# ── Embeddings ────────────────────────────────────────────────────────────────
# Set true for Railway/production (no PyTorch required)
USE_OPENROUTER=true
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages:

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=5
